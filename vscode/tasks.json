{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build & Run",
      "type": "shell",
      "command": "build_run.bat",
      "args": ["${file}"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Expand",
      "type": "shell",
      "command": "expand_cpp.bat",
      "args": ["${file}"]
    },
    {
      "label": "Build (Debug)",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++20",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}/solve.exe"
      ],
      "problemMatcher": ["$gcc"]
    }
  ]
}
